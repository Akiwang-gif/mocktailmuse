{
  "name": "homerio",
  "package": "@contentforge/theme-homerio",
  "type": "frontend-theme",
  "version": "homerio-theme-v1",
  "description": "ContentForge first frontend theme extracted from Homerio design",
  "capabilities": [
    "home-living",
    "article-cards",
    "category-cards",
    "homepage-layouts",
    "pagination",
    "theme-tokens",
    "component-styles"
  ],
  "components": {
    "registry": {
      "articleCard": {
        "file": "components/EditorialArticleCard.tsx",
        "export": "EditorialArticleCard",
        "type": "server-component"
      },
      "categoryCard": {
        "file": "components/HomeCategoryCard.tsx",
        "export": "HomeCategoryCard",
        "type": "server-component"
      },
      "featuredGrid": {
        "file": "components/FeaturedGrid.tsx",
        "export": "FeaturedGrid",
        "type": "server-component"
      },
      "latestArticlesGrid": {
        "file": "components/LatestArticlesGrid.tsx",
        "export": "LatestArticlesGrid",
        "type": "server-component"
      },
      "categoryGrid": {
        "file": "components/HomeCategoryGrid.tsx",
        "export": "HomeCategoryGrid",
        "type": "server-component"
      },
      "footerAccordionSection": {
        "file": "components/FooterAccordionSection.tsx",
        "export": "FooterAccordionSection",
        "type": "client-component"
      },
      "homeSectionHeading": {
        "file": "components/HomeSectionHeading.tsx",
        "export": "HomeSectionHeading",
        "type": "server-component"
      },
      "pagination": {
        "file": "components/Pagination.tsx",
        "export": "Pagination",
        "type": "server-component"
      }
    }
  },
  "sections": {
    "registry": {
      "hero": {
        "file": "sections/HomeHero.tsx",
        "export": "HomeHero"
      },
      "categoryShowcase": {
        "file": "sections/CategoryShowcaseSection.tsx",
        "export": "CategoryShowcaseSection"
      },
      "featuredArticles": {
        "file": "sections/FeaturedArticlesSection.tsx",
        "export": "FeaturedArticlesSection"
      },
      "latestArticles": {
        "file": "sections/LatestArticlesSection.tsx",
        "export": "LatestArticlesSection"
      },
      "newsletter": {
        "file": "sections/NewsletterBlock.tsx",
        "export": "NewsletterBlock"
      }
    }
  },
  "layouts": {
    "registry": {
      "homepage": {
        "file": "layouts/HomepageLayout.tsx",
        "export": "HomepageLayout"
      }
    }
  },
  "shell": {
    "registry": {
      "header": {
        "file": "shell/HeaderShell.tsx",
        "export": "HeaderShell"
      },
      "footer": {
        "file": "shell/FooterShell.tsx",
        "export": "FooterShell"
      }
    }
  },
  "tokens": {
    "colors": true,
    "typography": true,
    "spacing": true,
    "effects": true
  },
  "styles": {
    "tokens": true,
    "components": true,
    "entry": "styles/index.css"
  }
}
